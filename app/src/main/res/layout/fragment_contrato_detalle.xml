<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloContrato"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Información del Contrato"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/lblCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Código Contrato"
            android:textColor="#03DAC5"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloContrato"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etCodigoContrato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/lblCodigo"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblInicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Inicio"
            android:textColor="#03DAC5"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etCodigoContrato"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etFechaInicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/lblInicio"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblFin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha de Finalización"
            android:textColor="#03DAC5"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etFechaInicio"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etFechaFin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/lblFin"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monto de Alquiler"
            android:textColor="#03DAC5"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etFechaFin"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etMontoAlquiler"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/lblMonto"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/lblInquilino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inquilino"
            android:textColor="#03DAC5"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMontoAlquiler"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etInquilino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/lblInquilino"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/etInmuebleContrato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/etInquilino"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnPagos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:text="VER PAGOS"
            app:layout_constraintTop_toBottomOf="@id/etInmuebleContrato"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>