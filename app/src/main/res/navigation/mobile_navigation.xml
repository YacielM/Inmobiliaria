<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/inicioFragment">

    <fragment
        android:id="@+id/inicioFragment"
        android:name="com.example.inmobiliariaapp.ui.inicio.InicioFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_inicio" />

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.example.inmobiliariaapp.ui.perfil.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil" >
        <action
            android:id="@+id/action_perfil_to_cambioPass"
            app:destination="@id/cambioPassFragment" />
    </fragment>

    <fragment
        android:id="@+id/cambioPassFragment"
        android:name="com.example.inmobiliariaapp.ui.perfil.ChangePassFragment"
        android:label="Cambio contraseña"
        tools:layout="@layout/fragment_cambio_pass" />

</navigation>
